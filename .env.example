# Salin file ini jadi .env lalu isi nilai asli. Jangan commit .env.

# --- Database (dipakai packages/database & apps/api) ---
# Port host 5434 (bukan default 5432) — docker-compose.yml maps postgres ke "5434:5432" karena
# 5432/5433 sering sudah dipakai instance Postgres lain di mesin dev (native atau project lain).
DATABASE_URL="postgresql://deacad:deacad@localhost:5434/deacad?schema=public"

# --- Redis (dipakai BullMQ di apps/api & apps/worker) ---
REDIS_HOST="localhost"
REDIS_PORT="6379"

# --- JWT (dipakai apps/api) ---
JWT_ACCESS_SECRET="ganti-dengan-random-string-panjang"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="ganti-dengan-random-string-panjang-berbeda"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Midtrans (dipakai apps/api, module transactions) ---
MIDTRANS_SERVER_KEY="Mid-server-xxxxxxxxxxxx"
MIDTRANS_CLIENT_KEY="Mid-client-xxxxxxxxxxxx"
MIDTRANS_IS_PRODUCTION="false"

# --- Transactional email (dipakai apps/api, module auth) ---
# Kosongkan ("") kalau belum ada key Resend — EmailService sengaja cuma log link verifikasi ke
# console selama kosong. Isi placeholder ("re_xxx...") malah bikin dia coba call Resend sungguhan
# dan gagal 401 tanpa cara lihat link verifikasinya (lihat CLAUDE.md "Known local dev gotchas").
EMAIL_PROVIDER_API_KEY=""
EMAIL_FROM="noreply@deacad.example"

# --- Object storage file asli & hasil convert (dipakai api & worker) ---
STORAGE_ENDPOINT="http://localhost:9000"
STORAGE_ACCESS_KEY="minioadmin"
STORAGE_SECRET_KEY="minioadmin"
STORAGE_BUCKET="deacad"

# --- CORS (dipakai apps/api) ---
CORS_ORIGIN="http://localhost:3000"

# --- Next.js (dipakai apps/web) ---
NEXT_PUBLIC_API_URL="http://localhost:4000"

# --- App port ---
API_PORT="4000"
