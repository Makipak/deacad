// Schema sengaja hanya berisi model — semua config environment (DATABASE_URL dll)
// dipindah ke prisma.config.ts sejak Prisma ORM 7.

datasource db {
  provider = "postgresql"
  // Tanpa "url" di sini — diambil dari prisma.config.ts saat CLI jalan.
}

generator client {
  provider = "prisma-client" // generator baru rust-free (pengganti "prisma-client-js").
  output   = "../src/generated/prisma" // wajib diisi eksplisit sejak v7, tidak lagi ke node_modules.
}

// --- Enum ---

enum UserRole {
  user
  admin
}

enum FileType {
  pdf
  pptx
}

enum DocumentStatus {
  processing
  ready
  failed
  rejected
}

enum TransactionType {
  upload
  download
}

enum TransactionStatus {
  pending
  paid
  failed
  expired
  refunded
}

enum ReportStatus {
  pending
  resolved
  dismissed
}

// --- Model ---

model User {
  id            String   @id @default(cuid()) // cuid, bukan auto-increment — cegah ID enumerable (ARCHITECTURE.md #7).
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash") // hash bcrypt, tidak pernah keluar lewat API response.
  role          UserRole @default(user)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  documents             Document[]
  transactions          Transaction[]
  documentAccess        DocumentAccess[]
  reports               Report[]
  auditLogs             AuditLog[]         @relation("AuditLogAdmin")
  emailVerificationTokens EmailVerificationToken[]
  refreshTokens         RefreshToken[]

  @@map("users")
}

model Category {
  id   String @id @default(cuid())
  name String @unique

  documents Document[]

  @@map("categories")
}

model Document {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  title             String
  description       String?
  fileType          FileType       @map("file_type")
  originalFileUrl   String         @map("original_file_url")
  convertedPdfUrl   String?        @map("converted_pdf_url") // null selagi status masih processing.
  status            DocumentStatus @default(processing)
  categoryId        String?        @map("category_id")
  viewCount         Int            @default(0) @map("view_count")
  downloadCount     Int            @default(0) @map("download_count")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  // Full-text search — di-generate DB, isinya union title (bobot A) + description (bobot B).
  // Prisma tidak generate kolom tsvector langsung, jadi dibuat lewat migration SQL manual (lihat ARCHITECTURE.md #11).
  // Kolom ini dipetakan Unsupported supaya Prisma tahu kolomnya ada tapi tidak mencoba mengelola tipe-nya.
  searchVector Unsupported("tsvector")? @map("search_vector")

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pages    DocumentPage[]
  transactions Transaction[]
  access   DocumentAccess[]
  reports  Report[]

  @@index([status])
  @@index([categoryId])
  @@map("documents")
}

model DocumentPage {
  id             String  @id @default(cuid())
  documentId     String  @map("document_id")
  pageNumber     Int     @map("page_number")
  imageUrl       String  @map("image_url")
  isWatermarked  Boolean @default(false) @map("is_watermarked")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber]) // satu nomor halaman cuma boleh sekali per dokumen.
  @@map("document_pages")
}

model Transaction {
  id              String             @id @default(cuid())
  userId          String             @map("user_id")
  documentId      String             @map("document_id")
  type            TransactionType
  // Snapshot harga saat transaksi dibuat — BUKAN referensi live ke settings (ARCHITECTURE.md #4).
  amount          Int
  midtransOrderId String             @unique @map("midtrans_order_id")
  idempotencyKey  String             @unique @map("idempotency_key") // constraint DB, bukan cuma cek manual — cegah race condition.
  status          TransactionStatus  @default(pending)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId, documentId, type, status]) // dipakai cek transaksi pending duplikat sebelum bikin baru.
  @@map("transactions")
}

model DocumentAccess {
  userId     String   @map("user_id")
  documentId String   @map("document_id")
  grantedAt  DateTime @default(now()) @map("granted_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@id([userId, documentId]) // composite PK — satu user cuma butuh satu bukti akses per dokumen.
  @@map("document_access")
}

model Settings {
  key   String @id
  value Json // contoh: { "uploadPaymentEnabled": true, "uploadPrice": 15000, ... }

  @@map("settings")
}

model Report {
  id         String       @id @default(cuid())
  documentId String       @map("document_id")
  reporterId String       @map("reporter_id")
  reason     String
  status     ReportStatus @default(pending)
  createdAt  DateTime     @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reporter User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status, createdAt]) // dipakai query antrian moderasi: pending, urut terlama.
  @@map("reports")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  action    String // contoh: "settings.update", "document.unpublish", "transaction.refund".
  targetId  String   @map("target_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  admin User @relation("AuditLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@map("audit_logs")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  // Disimpan sebagai hash SHA-256, bukan plaintext (ARCHITECTURE.md #8) — token asli hanya dikirim lewat email.
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// Bukan bagian skema inti ARCHITECTURE.md #4, tapi wajib ada untuk mendukung
// refresh token rotation + reuse detection yang dijelaskan di ARCHITECTURE.md #8.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash") // hash SHA-256, cookie cuma simpan token mentah.
  familyId  String   @map("family_id") // satu family = satu rantai rotasi; reuse token lama = revoke se-family.
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@map("refresh_tokens")
}
